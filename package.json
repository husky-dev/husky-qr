{
  "name": "husky-qr",
  "version": "1.0.2",
  "main": "index.js",
  "author": "Jaroslav Khorishchenko <jaro@husky-dev.me>",
  "license": "MIT",
  "scripts": {
    "dev": "node esbuild.js --serve",
    "dist": "node esbuild.js",
    "test": "jest",
    "lint": "npm run lint:types && npm run lint:eslint",
    "lint:types": "tsc --noEmit --skipLibCheck",
    "lint:eslint": "eslint \"src/**\"",
    "lint:format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "snippets": "npx md2snipp --root .vscode/snippets --output .vscode"
  },
  "lint-staged": {
    "{*.ts,*tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "0.5.19",
    "daisyui": "5.5.19",
    "postcss": "8.5.10",
    "qrcode.react": "4.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-qr-reader": "3.0.0-beta-1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "autoprefixer": "10.5.0",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "jest": "30.3.0",
    "prettier": "3.8.3",
    "tmp": "0.2.5",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "zod": "4.3.6"
  }
}
